FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git ca-certificates

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /build/chain-indexer ./apps/chain-indexer

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /build/chain-indexer /usr/local/bin/chain-indexer

CMD ["chain-indexer"]
